<view class="page">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="logo">广金网</view>
    <view class="tag">金属行情导航</view>
  </view>

  <!-- 搜索框 -->
  <view class="search-box">
    <input class="search-input" placeholder="搜索行情网站" placeholder-class="placeholder" bindinput="onSearch" />
    <button class="search-btn" bindtap="doSearch">搜索</button>
  </view>

  <!-- 行情卡片 -->
  <scroll-view class="card-list" scroll-y="{{true}}">
    
    <!-- 伦敦行情 -->
    <view class="card">
      <view class="card-icon" style="background-color:#0D4C8F;">🌍</view>
      <view class="card-content">
        <view class="title">伦敦行情</view>
        <view class="desc">全球金属报价</view>
        <view class="url">mi818.com</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="https://3g.mi818.com">打开</button>
    </view>

    <!-- 南海铝锭 -->
    <view class="card">
      <view class="card-icon" style="background-color:#E63946;">🏭</view>
      <view class="card-content">
        <view class="title">南海铝锭</view>
        <view class="desc">铝锭实时报价</view>
        <view class="url">lvdingjia.com</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="https://www.lvdingjia.com">打开</button>
    </view>

    <!-- 佛山报价 -->
    <view class="card">
      <view class="card-icon" style="background-color:#FFA726;">🏢</view>
      <view class="card-content">
        <view class="title">佛山报价</view>
        <view class="desc">铜铝不锈钢行情</view>
        <view class="url">ccmn.cn</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="https://m.ccmn.cn/mhangqing/">打开</button>
    </view>

    <!-- 废旧市场 -->
    <view class="card">
      <view class="card-icon" style="background-color:#6A994E;">♻️</view>
      <view class="card-content">
        <view class="title">废旧市场</view>
        <view class="desc">废料价格行情</view>
        <view class="url">feijiu.net</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="https://baojia.feijiu.net">打开</button>
    </view>

    <!-- 报价预测 -->
    <view class="card">
      <view class="card-icon" style="background-color:#8E44AD;">📈</view>
      <view class="card-content">
        <view class="title">报价预测</view>
        <view class="desc">价格趋势分析</view>
        <view class="url">feijiu.net</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="https://baojia.feijiu.net/price-p-cid-bjcid-dqid22.-.html">打开</button>
    </view>

    <!-- 今日黄金 -->
    <view class="card">
      <view class="card-icon" style="background-color:#FFD700;">💰</view>
      <view class="card-content">
        <view class="title">今日黄金</view>
        <view class="desc">黄金价格走势</view>
        <view class="url">cngold.org</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="https://m.cngold.org/home/lm13/">打开</button>
    </view>

    <!-- 金属快讯 -->
    <view class="card">
      <view class="card-icon" style="background-color:#1D3557;">📰</view>
      <view class="card-content">
        <view class="title">金属快讯</view>
        <view class="desc">行业新闻动态</view>
        <view class="url">fsmi818.com</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="http://www.fsmi818.com/news/list_pid_9.html">打开</button>
    </view>

    <!-- 中金信息 -->
    <view class="card">
      <view class="card-icon" style="background-color:#457B9D;">📊</view>
      <view class="card-content">
        <view class="title">中金信息</view>
        <view class="desc">金融信息汇总</view>
        <view class="url">metalsinfo.com</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="https://www.metalsinfo.com/newsflash/index.html">打开</button>
    </view>

    <!-- 7x24快讯 -->
    <view class="card">
      <view class="card-icon" style="background-color:#1B9AAA;">⏰</view>
      <view class="card-content">
        <view class="title">7x24快讯</view>
        <view class="desc">全天候行情资讯</view>
        <view class="url">fx678.com</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="https://www.fx678.com/kx">打开</button>
    </view>

    <!-- 历史报价 -->
    <view class="card">
      <view class="card-icon" style="background-color:#2A9D8F;">📅</view>
      <view class="card-content">
        <view class="title">历史报价</view>
        <view class="desc">铝价历史数据</view>
        <view class="url">alu.cn</view>
      </view>
      <button class="card-btn" bindtap="openUrl" data-url="https://hq.alu.cn/3/35/p197/">打开</button>
    </view>

  </scroll-view>

  <!-- 底部 -->
  <view class="footer">
    <view class="footer-text">广金网 · 金属行情导航</view>
  </view>
</view>