/* Web 页面样式 */
.web-container {
  height: 100vh;
}

.header {
  height: 60px;
  background-color: #1A1D2F;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.back-btn {
  color: #FFD700;
  font-size: 16px;
}
.title {
  color: #FFF;
  font-size: 16px;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
}

.placeholder {
  width: 60px;
}

web-view {
  height: calc(100vh - 60px);
}
